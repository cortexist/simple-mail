{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "simple-mail",
  "identifier": "com.cortexist.simple-mail",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:2040",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Mail",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 750,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
